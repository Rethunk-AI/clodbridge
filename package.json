{
  "name": "clodbridge",
  "version": "1.0.0",
  "description": "MCP server bridging Cursor Rules, Skills, and Agents to Claude Code",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rethunk-AI/clodbridge.git"
  },
  "bugs": {
    "url": "https://github.com/Rethunk-AI/clodbridge/issues"
  },
  "homepage": "https://github.com/Rethunk-AI/clodbridge#readme",
  "type": "module",
  "bin": {
    "clodbridge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "micromatch": "^4.0.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.11",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
