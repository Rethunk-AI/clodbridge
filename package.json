{
  "name": "clodbridge",
  "version": "1.0.0",
  "description": "MCP server bridging Cursor Rules, Skills, and Agents to Claude Code",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rethunk-AI/clodbridge.git"
  },
  "bugs": {
    "url": "https://github.com/Rethunk-AI/clodbridge/issues"
  },
  "homepage": "https://github.com/Rethunk-AI/clodbridge#readme",
  "type": "module",
  "bin": {
    "clodbridge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "micromatch": "^4.0.8",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "zod": "3.25.76",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.18",
    "fast-uri": "^3.1.2",
    "postcss": "^8.5.10",
    "vite": "^7.3.2",
    "ip-address": "^10.1.1"
  }
}
