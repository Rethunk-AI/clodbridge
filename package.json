{
  "name": "clodbridge",
  "version": "1.0.0",
  "description": "MCP server bridging Cursor Rules, Skills, and Agents to Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rethunk-Tech/clodbridge.git"
  },
  "bugs": {
    "url": "https://github.com/Rethunk-Tech/clodbridge/issues"
  },
  "homepage": "https://github.com/Rethunk-Tech/clodbridge#readme",
  "type": "module",
  "bin": {
    "clodbridge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "micromatch": "^4.0.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
